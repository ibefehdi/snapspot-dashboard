# Server
HOST=0.0.0.0
PORT=3000

# SSH
SSH_USER=snapspot
SSH_CONCURRENCY=15
SSH_USE_CONTROL_MASTER=true
SSH_TIMEOUT_MS=10000

# Polling
POLL_TAILSCALE_MS=15000
POLL_AGENT_MS=30000
JOURNEY_STALE_MIN=15

# Logs on agents
LOG_DIR=/home/snapspot/.local/share/com.snapspot.dev/logs

# Tailscale tag filter
TAILSCALE_TAG=tag:snapspot

# Alerts
ALERTS_ENABLED=false
NTFY_TOPIC=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_OFFLINE_MIN=5
ALERT_APP_DOWN_MIN=2
ALERT_ERROR_STREAK=3
ALERT_CPU_TEMP_C=80
ALERT_DEBOUNCE_MIN=60

# ClickHouse (optional — history tab hidden if unset)
CLICKHOUSE_URL=https://mbm06nokae.eu-central-1.aws.clickhouse.cloud:8443
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default
CLICKHOUSE_TABLE=app_logs_etl
